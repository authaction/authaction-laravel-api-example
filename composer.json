{
    "name": "authaction/authaction-laravel-api-example",
    "description": "AuthAction JWKS JWT validation example for Laravel",
    "type": "project",
    "require": {
        "php": "^8.4",
        "laravel/framework": "^11.0",
        "authaction/authaction-php-sdk": "^0.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-install-cmd": [
            "@php artisan key:generate --ansi --no-interaction"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "audit": {
            "abandoned": "ignore"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
